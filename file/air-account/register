<title>Register - Air Uniform Account</title>
<div id=display></div>
<script src=https://cdn.jsdelivr.net/gh/pig-cmd/pig-cmd.github.io/bmobSDK.js></script>
<script>
document.querySelector("#display").innerHTML = "<div style=text-align:center><span style=font-size:2em;color:red>Register - Air Uniform Account</span><br>Username<input type='text' id='username' placeholder='Username' maxlength='24'><br>Password<input type='password' id='password' placeholder=Password maxlength=16><br>Please input your password again<br><input type=password id=password_r maxlength=16><br><input type='button' value='Register' onclick='javascript:user_register();'><br><a href='login'>Registered?Click me to login.</a><br></div>";   Bmob.initialize("88ae889891d99fe7", "000427");   var username = getcookie("token"); if (username != null){  document.querySelector("#display").innerHTML = "<div style=text-align:center><span style=font-size:2em;color:red>Air Uniform Account</span>You have signed in.<br><button onclick=javascript:logout();>Logout</button></div>"; }; function user_register(){       var username = document.querySelector("#username").value;  var password = document.querySelector("#password").value;  var password_r = document.querySelector("#password_r").value;  if (password != password_r){   alert("Passwords do not match");   return;  };   var username_pattern = /^[a-zA-Z][a-zA-Z0-9_]{3,23}$/i;  var password_pattern = /^(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,64}$/;  if (!username_pattern.test(username)){   alert("The user name should be 4 to 24 letters starting with letters and  containing only letters, numbers, and underscores");   return;  };  if (!password_pattern.test(password)){   alert("The password should be 8 to 64 letters,  containing at least one capital letter,  one lowercase letter, and one number");   return;  };  Bmob.register({username:username,password:password,email:null,phone:null}).then(function(res){   alert("The registration was successful.");   setcookie("token",btoa(username),60 * 1000 * 1000 * 24 * 3);   location.reload();  }).catch(function(err){   console.log(err);  });  }; function logout(){  delcookie("token",1000 * 60 * 60 * 24 * 3);  location.reload(); };                                   function setcookie(name,value,time) {        var exp = new Date();          exp.setTime(exp.getTime() + time);          document.cookie = name + "=" + escape(value) + ";expires=" + exp.toGMTString() + ";path=/";   } function getcookie(name) {          var arr, reg = new RegExp("(^| )" + name + "=([^;]*)(;|$)");          if (arr = document.cookie.match(reg))   {            return unescape(arr[2]);   }        else  {            return null;   }    }   function delcookie(name,time) {          var exp = new Date();          exp.setTime(exp.getTime() - time);          var cval = getcookie(name);          if (cval != null)             document.cookie = name + "=" + cval + ";expires=" + exp.toGMTString() + ";path=/"; }
</script>
